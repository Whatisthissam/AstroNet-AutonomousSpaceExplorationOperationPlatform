# ==========================================
# AstroNet Platform Configuration Template
# ==========================================

# Node Environment (development | production | test)
NODE_ENV=development

# Port on which the API Backend runs
PORT=5000

# MongoDB Connection String
# For local development: mongodb://localhost:27017/astronet
# For docker-compose: mongodb://mongodb:27017/astronet
MONGO_URI=mongodb://localhost:27017/astronet

# Security Credentials
# IMPORTANT: Change these values in any staging or production deployments!
JWT_SECRET=astronet_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# Frontend Client Address (CORS protection whitelist)
CLIENT_URL=http://localhost:5173

# Application Logging Level (error | warn | info | http | debug)
LOG_LEVEL=info

# ==========================================
# DevOps & Enterprise Services Configuration
# ==========================================

# HashiCorp Vault Integration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Grafana Configuration
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ELK Stack Configuration
ELASTICSEARCH_ADDR=http://localhost:9200
KIBANA_PORT=5601
LOGSTASH_PORT=50000

# ==========================================
# Terraform Infrastructure Configuration Variables
# ==========================================

# Target Region for AWS Deployment
aws_region = "us-east-1"

# Environment tier tag
environment = "dev"

# VPC network CIDR blocks
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

# Kubernetes Cluster Config
cluster_name         = "astronet-eks-dev"
eks_instance_types   = ["t3.medium"]
eks_desired_capacity = 2

# MongoDB / DocumentDB Credentials Configuration
# IMPORTANT: Change the credentials before executing terraform apply!
db_username = "astronet_db_admin"
db_password = "SuperSecurePassword987!" # Must satisfy standard DB password policies
db_name     = "astronet"

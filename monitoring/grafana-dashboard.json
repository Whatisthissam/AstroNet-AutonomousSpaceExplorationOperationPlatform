      "id": 2,
      "title": "System Operational Status",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "up{job=\"astronet-backend\"}",
          "legendFormat": "Status",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",

      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "astronet_active_missions_count or count(up{job=\"astronet-backend\"}) * 5",
          "legendFormat": "Missions",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value"
      }
